---
---
<button
  id="theme-toggle"
  type="button"
  aria-label="Toggle color theme"
  class="text-[0.7rem] tracking-[0.22em] uppercase text-muted hover:text-app transition-colors cursor-pointer"
>
  <span data-theme-label-light>Dark mode</span>
  <span data-theme-label-dark class="hidden">Light mode</span>
</button>

<script is:inline>
  (function () {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    const lightLabel = btn.querySelector('[data-theme-label-light]');
    const darkLabel = btn.querySelector('[data-theme-label-dark]');

    function sync() {
      const t = document.documentElement.getAttribute('data-theme');
      if (t === 'dark') {
        lightLabel.classList.add('hidden');
        darkLabel.classList.remove('hidden');
      } else {
        lightLabel.classList.remove('hidden');
        darkLabel.classList.add('hidden');
      }
    }

    sync();

    btn.addEventListener('click', function () {
      const current = document.documentElement.getAttribute('data-theme') ?? 'light';
      const next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      try { localStorage.setItem('meridian-theme', next); } catch (_) {}
      sync();
    });
  })();
</script>
